type NFT = 
 service {
   getCanisterId: () -> (principal) query;
   getContent: () -> (text) query;
   getCoverImage: () -> (vec nat8) query;
   getLabel: () -> (text) query;
   getOwner: () -> (principal) query;
   transferOwnership: (newOwner: principal) -> (text);
 };
service : (name: text, owner: principal, content: text, coverImage: vec nat8) -> NFT
